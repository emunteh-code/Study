---
import Button from "../../components/foundation/Button.astro";
import Card from "../../components/foundation/Card.astro";
import PageHeader from "../../components/foundation/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getRegisteredModules } from "../../learning/registry";

const practiceEntriesByRoute = new Map<
  string,
  {
    module: ReturnType<typeof getRegisteredModules>[number];
    sessionTitles: string[];
    practiceTitle: string;
    objectiveIds: string[];
    availability: string;
  }
>();

for (const module of getRegisteredModules()) {
  for (const session of module.sessions) {
    for (const mapping of session.practiceMappings) {
      const existing = practiceEntriesByRoute.get(mapping.practiceRoute);
      if (existing) {
        existing.sessionTitles.push(session.title);
        existing.objectiveIds.push(...mapping.objectiveIds);
      } else {
        practiceEntriesByRoute.set(mapping.practiceRoute, {
          module,
          sessionTitles: [session.title],
          practiceTitle: mapping.practiceTitle,
          objectiveIds: [...mapping.objectiveIds],
          availability: mapping.availability,
        });
      }
    }
  }
}

const practiceEntries = [...practiceEntriesByRoute.entries()];
---

<BaseLayout
  title="Üben"
  description="Wähle ein verfügbares Übungsset und arbeite in deinem Tempo."
  canonicalPath="/ueben/"
  breadcrumbs={[{ label: "Startseite", href: "/" }, { label: "Üben" }]}
>
  <section class="module-page" aria-labelledby="page-title">
    <PageHeader
      eyebrow="Übungsbereich"
      title="Üben"
      summary="Wähle einen aktuell verfügbaren Bereich. Die Zuordnung zu Modulen, Sitzungen und Lernzielen kommt aus dem gemeinsamen Modulmodell."
    />
    <div class="home-grid home-grid--modules">
      {
        practiceEntries.map(([practiceRoute, entry]) => (
          <Card
            title={`${entry.module.shortTitle ?? entry.module.title}: ${entry.practiceTitle}`}
            metadata={entry.sessionTitles.join(" · ")}
          >
            <p>
              Zugeordnete Ziele: {[...new Set(entry.objectiveIds)].join(", ")}
            </p>
            <p class="card__meta">Verfügbarkeit: {entry.availability}</p>
            <div slot="footer" class="card-actions">
              <Button href={practiceRoute} variant="secondary">
                Übungsset öffnen
              </Button>
            </div>
          </Card>
        ))
      }
    </div>
  </section>
</BaseLayout>
