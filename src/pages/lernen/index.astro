---
import Button from "../../components/foundation/Button.astro";
import Callout from "../../components/foundation/Callout.astro";
import Card from "../../components/foundation/Card.astro";
import PageHeader from "../../components/foundation/PageHeader.astro";
import SectionHeader from "../../components/foundation/SectionHeader.astro";
import StatusLabel from "../../components/foundation/StatusLabel.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublicLearningModules } from "../../learning/registry";
import { moduleLearningRoute } from "../../learning/routing";

const modules = getPublicLearningModules();
const firstModule = modules[0];
---

<BaseLayout
  title="Lernen"
  description="Wähle einen registrierten Lernbereich und beginne mit dem nächsten sinnvollen Schritt."
  canonicalPath="/lernen/"
  breadcrumbs={[{ label: "Startseite", href: "/" }, { label: "Lernen" }]}
>
  <section class="module-page" aria-labelledby="page-title">
    <PageHeader
      eyebrow="Lernbereich"
      title="Lernen"
      summary="Wähle einen registrierten Lernbereich. Die Struktur kommt aus dem wiederverwendbaren Modulmodell, nicht aus fachgebundenen Einzelseiten."
    >
      {
        firstModule && (
          <Button slot="actions" href={moduleLearningRoute(firstModule)}>
            {firstModule.title} öffnen
          </Button>
        )
      }
    </PageHeader>
    <Callout title="Verfügbare Inhalte" variant="information">
      <p>
        Mikroökonomik I ist aktuell die erste öffentliche Implementierung der
        wiederverwendbaren Lernarchitektur. Weitere Module werden erst nach
        Quellenprüfung und Registrierung sichtbar.
      </p>
    </Callout>
    <section class="home-section" aria-labelledby="learning-modules-title">
      <SectionHeader
        id="learning-modules-title"
        title="Registrierte Lernbereiche"
        summary="Weitere Module sollen künftig durch Daten, Quellenprüfung und Registrierung ergänzt werden, ohne die Seitenstruktur neu zu bauen."
      />
      <div class="home-grid home-grid--modules">
        {
          modules.map((module) => (
            <Card
              title={module.title}
              metadata={`${module.subjectArea} · ${module.sessions.length} Sitzungen`}
            >
              <div class="module-card__status">
                <StatusLabel
                  label={`Architektur: ${module.availability.architecture}`}
                  tone="success"
                />
                <StatusLabel
                  label={`Praxis: ${module.availability.practice}`}
                  tone="info"
                />
              </div>
              <p>{module.description}</p>
              <p class="card__meta">
                Lektionen: {module.availability.lessons}. Quellen:{" "}
                {module.availability.sourceStatus}.
              </p>
              <div slot="footer" class="card-actions">
                <Button href={moduleLearningRoute(module)} variant="secondary">
                  Kursübersicht öffnen
                </Button>
              </div>
            </Card>
          ))
        }
      </div>
    </section>
  </section>
</BaseLayout>
