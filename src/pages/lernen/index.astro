---
import Button from "../../components/foundation/Button.astro";
import Callout from "../../components/foundation/Callout.astro";
import Card from "../../components/foundation/Card.astro";
import PageHeader from "../../components/foundation/PageHeader.astro";
import SectionHeader from "../../components/foundation/SectionHeader.astro";
import StatusLabel from "../../components/foundation/StatusLabel.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Lernen"
  description="Wähle einen verfügbaren Lernbereich und beginne mit dem nächsten sinnvollen Schritt."
  canonicalPath="/lernen/"
  breadcrumbs={[{ label: "Startseite", href: "/" }, { label: "Lernen" }]}
>
  <section class="module-page" aria-labelledby="page-title">
    <PageHeader
      eyebrow="Lernbereich"
      title="Lernen"
      summary="Wähle einen Lernbereich und starte mit dem nächsten sinnvollen Schritt."
    >
      <Button slot="actions" href="/lernen/mikrooekonomik-1/">
        Mikroökonomik I öffnen
      </Button>
    </PageHeader>
    <Callout title="Verfügbare Inhalte" variant="information">
      <p>
        Mikroökonomik I ist als reviewbereiter Lernpfad mit zwei Übungsbereichen
        verfügbar.
      </p>
    </Callout>
    <section class="home-section" aria-labelledby="learning-modules-title">
      <SectionHeader
        id="learning-modules-title"
        title="Verfügbare Lernbereiche"
        summary="Wähle einen verfügbaren Kursbereich."
      />
      <div class="home-grid home-grid--modules">
        <Card title="Mikroökonomik I" metadata="Zwei Übungsbereiche">
          <div class="module-card__status">
            <StatusLabel label="Verfügbar" tone="success" />
          </div>
          <p>
            Beginne mit Präferenzrelationen und setze mit
            Substitutionselastizität fort.
          </p>
          <p class="card__meta">
            Originale Übungsinhalte mit nachvollziehbarer Quellenbasis.
          </p>
          <div slot="footer" class="card-actions">
            <Button href="/lernen/mikrooekonomik-1/" variant="secondary">
              Kursübersicht öffnen
            </Button>
          </div>
        </Card>
      </div>
    </section>
  </section>
</BaseLayout>
