---
import ModuleOverview from "../../../components/learning/ModuleOverview.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getRequiredModuleBySlug } from "../../../learning/registry";

const module = getRequiredModuleBySlug("mikrooekonomik-1");
---

<BaseLayout
  title={module.title}
  description={module.description}
  canonicalPath="/lernen/mikrooekonomik-1/"
  robots="noindex, follow"
  breadcrumbs={[
    { label: "Startseite", href: "/" },
    { label: "Lernen", href: "/lernen/" },
    { label: module.title },
  ]}
>
  <ModuleOverview module={module} />
</BaseLayout>
