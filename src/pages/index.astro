---
import HomepageSurface from "../components/home/HomepageSurface.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { toBasePath } from "../lib/routes";

const returningFixtureHref = toBasePath("/fixtures/homepage/returning/");
---

<BaseLayout
  title="VWL Lernbegleiter Göttingen"
  description="Unabhängiger Lernbegleiter für Göttinger VWL-Studierende mit strukturierten Lernpfaden, Übungen und transparenter Quellenbasis."
  canonicalPath="/"
  ogTitle="VWL Lernbegleiter Göttingen"
  ogDescription="Unabhängiger Lernbegleiter für Göttinger VWL-Studierende mit strukturierten Lernpfaden, Übungen und transparenter Quellenbasis."
  pageId="homepage"
  rawTitle
>
  <HomepageSurface fixtureMode="new" />
  <script is:inline define:vars={{ returningFixtureHref }}>
    const homepageFixture = new URLSearchParams(window.location.search).get(
      "fixture",
    );

    if (homepageFixture === "returning") {
      window.location.replace(returningFixtureHref);
    }
  </script>
</BaseLayout>
