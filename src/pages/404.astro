---
import Button from "../components/foundation/Button.astro";
import PlaceholderPage from "../components/shell/PlaceholderPage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Seite nicht gefunden"
  description="Die angeforderte Seite wurde nicht gefunden."
  canonicalPath="/404/"
  robots="noindex, follow"
>
  <PlaceholderPage
    title="Seite nicht gefunden"
    summary="Die angeforderte Seite ist nicht verfügbar."
    status="Möglicherweise ist die Seite noch nicht angelegt oder die Adresse hat sich geändert."
  >
    <div class="placeholder-actions">
      <Button href="/">Zur Startseite</Button>
      <Button href="/lernen/" variant="secondary">Zum Lernbereich</Button>
    </div>
  </PlaceholderPage>
</BaseLayout>
