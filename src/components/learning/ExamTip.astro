---
interface Props {
  id?: string;
  title?: string;
  cue: string;
  guidance: string;
  commonTrap?: string;
  timeManagementNote?: string;
  provenanceStatus?: string;
}

const {
  id,
  title = "Exam Transfer",
  cue,
  guidance,
  commonTrap,
  timeManagementNote,
  provenanceStatus,
} = Astro.props;
const headingId = id ?? `${title}-tip`;
---

<section class="callout callout--note" aria-labelledby={headingId}>
  <h2 id={headingId}>{title}</h2>
  <p><strong>Erkennen:</strong> {cue}</p>
  <p><strong>Übertragen:</strong> {guidance}</p>
  {
    commonTrap && (
      <p>
        <strong>Falle:</strong> {commonTrap}
      </p>
    )
  }
  {
    timeManagementNote && (
      <p>
        <strong>Zeitplanung:</strong> {timeManagementNote}
      </p>
    )
  }
  {provenanceStatus && <p class="card__meta">{provenanceStatus}</p>}
</section>
