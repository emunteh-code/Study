---
export interface Variable {
  symbol: string;
  meaning: string;
}

interface Props {
  id?: string;
  name: string;
  expression: string;
  purpose: string;
  variables: Variable[];
  assumptions?: string[];
  source?: string | undefined;
  commonMisuse?: string | undefined;
  sourceStatus?: string | undefined;
}

const {
  id,
  name,
  expression,
  purpose,
  variables,
  assumptions = [],
  source,
  commonMisuse,
  sourceStatus,
} = Astro.props;
const headingId = id ?? `${name}-formula`;
---

<section class="learning-block" aria-labelledby={headingId}>
  <h2 id={headingId}>{name}</h2>
  <p>{purpose}</p>
  <div class="formula-expression" aria-label={`Formel ${name}`}>
    {expression}
  </div>
  <h3>Variablen</h3>
  <dl class="metadata-list">
    {
      variables.map((variable) => (
        <>
          <dt>{variable.symbol}</dt>
          <dd>{variable.meaning}</dd>
        </>
      ))
    }
  </dl>
  {
    assumptions.length > 0 && (
      <>
        <h3>Annahmen</h3>
        <ul>
          {assumptions.map((assumption) => (
            <li>{assumption}</li>
          ))}
        </ul>
      </>
    )
  }
  {
    commonMisuse && (
      <p>
        <strong>Häufige Fehlverwendung:</strong> {commonMisuse}
      </p>
    )
  }
  {sourceStatus && <p class="card__meta">Quellenstatus: {sourceStatus}</p>}
  {source && <p class="card__meta">Quelle: {source}</p>}
</section>
