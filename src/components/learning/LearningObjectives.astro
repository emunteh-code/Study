---
export interface Objective {
  id?: string;
  text: string;
}

interface Props {
  id?: string;
  title?: string;
  objectives: Objective[];
}

const {
  id = "learning-objectives",
  title = "Lernziele",
  objectives,
} = Astro.props;
---

<section class="learning-block" aria-labelledby={id}>
  <h2 id={id}>{title}</h2>
  <ul>
    {objectives.map((objective) => <li id={objective.id}>{objective.text}</li>)}
  </ul>
</section>
