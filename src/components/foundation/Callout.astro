---
type Variant = "information" | "success" | "warning" | "danger" | "note";

interface Props {
  variant?: Variant;
  title?: string;
}

const { variant = "information", title } = Astro.props;
---

<div class={`callout callout--${variant}`} role="note">
  {title && <p class="callout__title">{title}</p>}
  <slot />
</div>
