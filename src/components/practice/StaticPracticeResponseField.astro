---
import AccessiblePracticeText from "./AccessiblePracticeText.astro";
import type { PracticeResponseField } from "../../lib/mikro1-preferences-practice";

interface Props {
  exerciseId: string;
  instructionsId: string;
  field: PracticeResponseField;
}

const { exerciseId, instructionsId, field } = Astro.props;
const fieldId = `${exerciseId}-${field.id}`;
---

{
  field.kind === "textarea" && (
    <div class="static-practice-field">
      <label for={fieldId}>{field.label}</label>
      {field.description && (
        <p id={`${fieldId}-description`}>{field.description}</p>
      )}
      <textarea
        id={fieldId}
        name={fieldId}
        aria-describedby={
          field.description
            ? `${instructionsId} ${fieldId}-description`
            : instructionsId
        }
        aria-required={field.required ? "true" : undefined}
        required={field.required}
        rows="4"
      />
    </div>
  )
}

{
  field.kind === "text" && (
    <div class="static-practice-field">
      <label for={fieldId}>{field.label}</label>
      {field.description && (
        <p id={`${fieldId}-description`}>{field.description}</p>
      )}
      <input
        id={fieldId}
        name={fieldId}
        type="text"
        aria-describedby={
          field.description
            ? `${instructionsId} ${fieldId}-description`
            : instructionsId
        }
        aria-required={field.required ? "true" : undefined}
        required={field.required}
      />
    </div>
  )
}

{
  field.kind === "select" && (
    <div class="static-practice-field">
      <label for={fieldId}>{field.label}</label>
      <select
        id={fieldId}
        name={fieldId}
        aria-describedby={instructionsId}
        aria-required={field.required ? "true" : undefined}
        required={field.required}
      >
        <option value="">Bitte auswählen</option>
        {field.options.map((option) => (
          <option value={option.id}>{option.label}</option>
        ))}
      </select>
    </div>
  )
}

{
  field.kind === "radio" && (
    <fieldset class="static-practice-field" aria-describedby={instructionsId}>
      <legend>{field.label}</legend>
      {field.options.map((option, index) => {
        const optionId = `${fieldId}-${option.id}`;

        return (
          <div class="static-practice-option">
            <input
              id={optionId}
              name={fieldId}
              type="radio"
              value={option.id}
              required={field.required && index === 0}
            />
            <label for={optionId}>
              <AccessiblePracticeText text={option.label} />
            </label>
          </div>
        );
      })}
    </fieldset>
  )
}
