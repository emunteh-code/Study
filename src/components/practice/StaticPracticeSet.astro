---
import Callout from "../foundation/Callout.astro";
import StaticPracticeExercise from "./StaticPracticeExercise.astro";
import Mikro1PracticeNavigation from "./Mikro1PracticeNavigation.astro";
import Mikro1PreferenceLesson from "./Mikro1PreferenceLesson.astro";
import Mikro1TopicOrientation from "./Mikro1TopicOrientation.astro";
import { mikro1PreferenceOrientation } from "../../data/mikro1-orientation";
import type { StaticMikro1PreferenceExercise } from "../../lib/mikro1-preferences-practice";

interface Props {
  exercises: StaticMikro1PreferenceExercise[];
}

const { exercises } = Astro.props;
const exerciseTitles = new Map(
  exercises.map((exercise) => [exercise.id, exercise.title]),
);
---

<div class="practice-page static-practice-set">
  <header class="static-practice-set__header">
    <p class="eyebrow">Mikroökonomik I</p>
    <h1>Präferenzrelationen lernen und üben</h1>
    <p>
      Eine vollständige Lernstrecke zu schwacher Präferenz, strikter Präferenz,
      Indifferenz, Vollständigkeit, Transitivität und rationalen
      Präferenzrelationen.
    </p>
  </header>

  <Mikro1PracticeNavigation current="preferences" />

  <Mikro1TopicOrientation
    orientation={mikro1PreferenceOrientation}
    exerciseTitles={exerciseTitles}
  />

  <Mikro1PreferenceLesson />

  <section
    data-practice-progress
    hidden
    aria-labelledby="practice-progress-title"
  >
    <h2 id="practice-progress-title">Practice completion</h2>
    <p data-practice-progress-summary role="status" aria-live="polite"></p>
    <ul data-practice-progress-remaining></ul>
    <button type="button" data-practice-progress-reset
      >Reset local completion</button
    >
  </section>

  <Callout title="Unabhängige Übungsphase" variant="information">
    <p>
      Die Lektion oben erklärt die Begriffe und zeigt gelöste Beispiele. Die
      folgenden Aufgaben prüfen, ob du die Begriffe selbst anwenden kannst.
      Antwortprüfung benötigt JavaScript; Aufgaben, Notation und Eingabefelder
      bleiben ohne JavaScript lesbar.
    </p>
  </Callout>

  <nav
    class="static-practice-overview"
    aria-labelledby="practice-overview-title"
  >
    <div>
      <p class="eyebrow">Übungskarte</p>
      <h2 id="practice-overview-title">Aufgabenkarten</h2>
    </div>
    <ol>
      {
        exercises.map((exercise, index) => (
          <li>
            <a href={`#${exercise.id}`} data-practice-map-link={exercise.id}>
              <span aria-hidden="true">{index + 1}</span>
              <span>{exercise.title}</span>
            </a>
          </li>
        ))
      }
    </ol>
  </nav>

  <section aria-labelledby="static-practice-instructions">
    <h2 id="static-practice-instructions">So nutzt du die Aufgaben</h2>
    <ol>
      <li>Lies Aufgabenstellung, Relationendaten und Annahmen sorgfältig.</li>
      <li>Nutze die Antwortfelder, um deine eigene Lösung zu strukturieren.</li>
      <li>
        Vergleiche Feedback mit den Definitionen aus der Lektion, nicht nur mit
        der ausgewählten Option.
      </li>
    </ol>
  </section>

  <section aria-labelledby="static-practice-notation">
    <h2 id="static-practice-notation">Notation in den Aufgaben</h2>
    <dl class="practice-data-list">
      <dt><span aria-label="is weakly preferred to">≽</span></dt>
      <dd>ist schwach präferiert gegenüber</dd>
      <dt><span aria-label="is strictly preferred to">≻</span></dt>
      <dd>ist strikt präferiert gegenüber</dd>
      <dt><span aria-label="is indifferent to">∼</span></dt>
      <dd>ist indifferent zu</dd>
    </dl>
  </section>

  <div class="static-practice-list">
    {
      exercises.map((exercise, index) => (
        <StaticPracticeExercise
          exercise={exercise}
          position={index + 1}
          total={exercises.length}
        />
      ))
    }
  </div>
</div>
