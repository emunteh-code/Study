---
import AccessiblePracticeText from "./AccessiblePracticeText.astro";
import StaticPracticeResponseField from "./StaticPracticeResponseField.astro";
import type { StaticMikro1PreferenceExercise } from "../../lib/mikro1-preferences-practice";

interface Props {
  exercise: StaticMikro1PreferenceExercise;
  instructionsId: string;
}

const { exercise, instructionsId } = Astro.props;
const feedbackId = `${exercise.id}-feedback`;
const evaluationKind =
  exercise.id === "pref-practice-07"
    ? "transitivity-chain"
    : exercise.interactionType;
---

<div class="static-practice-response">
  <h3 id={`${exercise.id}-response`}>Response</h3>
  <p id={instructionsId}>{exercise.responseDefinition.responseSummary}</p>
  <ul class="static-practice-instructions">
    {
      exercise.learnerVisibleContent.instructions.map((instruction) => (
        <li>
          <AccessiblePracticeText text={instruction} />
        </li>
      ))
    }
  </ul>
  {
    exercise.evaluationAvailable || exercise.selfReviewAvailable ? (
      <form
        {...(exercise.evaluationAvailable
          ? { "data-mikro1-evaluation-form": true }
          : { "data-mikro1-self-review-form": true })}
        data-exercise-id={exercise.id}
        data-evaluation-kind={evaluationKind}
        aria-describedby={instructionsId}
      >
        <div>
          {exercise.responseDefinition.fields.map((field) => (
            <StaticPracticeResponseField
              exerciseId={exercise.id}
              instructionsId={instructionsId}
              field={field}
            />
          ))}
        </div>
        <button
          class="button button--primary"
          type="submit"
          {...(exercise.evaluationAvailable
            ? { "data-evaluation-submit": true }
            : { "data-self-review-open": true })}
          disabled
        >
          {exercise.evaluationAvailable
            ? "Check answer"
            : "Compare with model solution"}
        </button>
        <p class="card__meta">
          {exercise.evaluationAvailable
            ? "Answer checking requires JavaScript."
            : "Comparison requires JavaScript."}
        </p>
        <div
          class="static-practice-feedback"
          id={feedbackId}
          {...(exercise.evaluationAvailable
            ? { "data-evaluation-feedback": true }
            : { "data-self-review-feedback": true })}
          role="status"
          aria-live="polite"
          aria-atomic="true"
          hidden
        >
          <h4
            {...(exercise.evaluationAvailable
              ? { "data-evaluation-feedback-heading": true }
              : { "data-self-review-feedback-heading": true })}
          />
          <p
            {...(exercise.evaluationAvailable
              ? { "data-evaluation-feedback-text": true }
              : { "data-self-review-feedback-text": true })}
          />
        </div>
        {exercise.selfReviewAvailable && (
          <section
            class="static-practice-comparison"
            data-self-review-panel
            hidden
            tabindex="-1"
          >
            <h4>Model solution comparison</h4>
            <div data-self-review-content />
            <button type="button" data-self-review-close>
              Close comparison
            </button>
          </section>
        )}
      </form>
    ) : (
      <div>
        {exercise.responseDefinition.fields.map((field) => (
          <StaticPracticeResponseField
            exerciseId={exercise.id}
            instructionsId={instructionsId}
            field={field}
          />
        ))}
        <p class="card__meta">
          Response evaluation is not available in this practice version.
        </p>
      </div>
    )
  }
</div>
