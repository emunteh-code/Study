---
import { siteConfig } from "../../config/site";
import { toBasePath } from "../../lib/routes";

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div>
      <p class="site-footer__name">{siteConfig.name}</p>
      <p>{siteConfig.disclaimer}</p>
      <p>© {currentYear} {siteConfig.shortName}</p>
    </div>

    <nav class="footer-nav" aria-label="Footer-Navigation">
      {
        siteConfig.footerNavigation.map((group) => (
          <section aria-labelledby={`footer-${group.label}`}>
            <h2 id={`footer-${group.label}`}>{group.label}</h2>
            <ul>
              {group.items.map((item) => (
                <li>
                  <a href={toBasePath(item.route)}>{item.label}</a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </nav>
  </div>
</footer>
